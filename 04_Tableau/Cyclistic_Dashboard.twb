      <column datatype='real' default-format='p0.00%' name='[Calculation1]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([ride_id]) / TOTAL(COUNTD([ride_id]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Member Percentage' datatype='real' name='[Calculation_0144607054868480]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(&#13;&#10;IF[member_casual]=&quot;member&quot;&#13;&#10;THEN [ride_id]&#13;&#10;END&#13;&#10;)&#13;&#10;/COUNTD([ride_id])' />
      </column>
      <column caption='Peak Hour' datatype='string' name='[Calculation_0144607154569218]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='&quot;17:00&quot;' />
      </column>
      <column caption='Avg Weekday Rides' datatype='integer' name='[Calculation_0144607177359363]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [day_type] = &quot;Weekday&quot; THEN 1 END' />
